{
  "components": {
    "schemas": {
      "ErrorResponse": {
        "description": "Shared envelope for every non-2xx response.\n\nAttributes\n----------\ndetail:\n    Human-readable summary of the failure (the FastAPI default error key).\nerrors:\n    Optional per-item failure lines. For scenario-validation failures this\n    is ''ScenarioValidationError.format_errors().splitlines()'' -- the **same\n    list** ''POST /api/v1/validate'' returns in its 200 body for the same\n    input -- so a client can render field errors identically regardless of\n    which endpoint rejected the scenario. ''None'' for errors that have no\n    line-level breakdown (404 / 409 / 401 / generic 400).",
        "properties": {
          "detail": {
            "title": "Detail",
            "type": "string"
          },
          "errors": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Errors"
          }
        },
        "required": [
          "detail"
        ],
        "title": "ErrorResponse",
        "type": "object"
      },
      "HealthResponse": {
        "description": "Response body for ''GET /health'' (public, unversioned liveness probe).\n\nAttributes\n----------\nstatus:\n    Always ''\"ok\"'' when the service is running.\nversion:\n    Installed ''samba-core'' package version string. **Display only** \u2014 do not\n    key API compatibility off it.\napi_version:\n    SemVer of the HTTP API surface (equals the OpenAPI ''info.version''); the\n    value an external client checks for compatibility. From\n    :data:'samba_service._contract.API_VERSION'.\ncontract_version:\n    Version of the published data/schema contract (OpenAPI + companion JSON\n    Schemas) the client generated its types from. From\n    :data:'samba_service._contract.CONTRACT_VERSION'.\ncapabilities:\n    Stable advertised feature flags the client may branch on\n    (:data:'samba_service._contract.CAPABILITIES').\nsolver:\n    Configured solver name (from :attr:'~samba_service.config.ServiceConfig.solver').\nsolver_ready:\n    ''True'' when the configured solver binary/package is importable.\nactive_jobs:\n    Number of jobs currently in ''PENDING'' or ''RUNNING'' state.\n\nThe three version axes (samba-core package, API/contract, and the OpenAPI\nspec version owned by FastAPI) are documented in\n:mod:'samba_service._contract'.",
        "properties": {
          "active_jobs": {
            "default": 0,
            "title": "Active Jobs",
            "type": "integer"
          },
          "api_version": {
            "title": "Api Version",
            "type": "string"
          },
          "capabilities": {
            "items": {
              "type": "string"
            },
            "title": "Capabilities",
            "type": "array"
          },
          "contract_version": {
            "title": "Contract Version",
            "type": "string"
          },
          "solver": {
            "title": "Solver",
            "type": "string"
          },
          "solver_ready": {
            "title": "Solver Ready",
            "type": "boolean"
          },
          "status": {
            "const": "ok",
            "default": "ok",
            "title": "Status",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "version",
          "api_version",
          "contract_version",
          "capabilities",
          "solver",
          "solver_ready"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "JobStatus": {
        "description": "Life-cycle state of a background solve job.",
        "enum": [
          "pending",
          "running",
          "completed",
          "failed"
        ],
        "title": "JobStatus",
        "type": "string"
      },
      "JobStatusResponse": {
        "description": "Response body for ''GET /api/v1/jobs/{run_id}''.\n\nAttributes\n----------\nrun_id:\n    UUID4 job identifier.\nstatus:\n    Current :class:'~samba_service.jobs.JobStatus'.\nsubmitted_at:\n    UTC timestamp of job submission.\nstarted_at:\n    UTC timestamp when the solver thread picked up the job, or ''None''.\ncompleted_at:\n    UTC timestamp of job completion (success or failure), or ''None''.\nkpis:\n    Typed :class:'~samba.run_result.contracts.KpiSummary'.  Present only when\n    ''status == \"completed\"''.  Degraded to ''None'' (with a logged warning)\n    if a persisted legacy row's stored KPIs no longer match the contract.\nsizing:\n    List of typed :class:'~samba.run_result.contracts.SizingRow'.  Present\n    only when ''status == \"completed\"''; degraded as above on legacy rows.\nartifacts:\n    List of downloadable filenames available under\n    ''GET /api/v1/jobs/{run_id}/artifacts/{filename}''.\n    Populated only when ''status == \"completed\"''.\nerror:\n    Human-readable error description when ''status == \"failed\"''.",
        "properties": {
          "artifacts": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Artifacts",
            "type": "array"
          },
          "completed_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "kpis": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/KpiSummary"
              },
              {
                "type": "null"
              }
            ]
          },
          "run_id": {
            "title": "Run Id",
            "type": "string"
          },
          "sizing": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/SizingRow"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sizing"
          },
          "solve_time_s": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Solve Time S"
          },
          "started_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "submitted_at": {
            "format": "date-time",
            "title": "Submitted At",
            "type": "string"
          }
        },
        "required": [
          "run_id",
          "status",
          "submitted_at"
        ],
        "title": "JobStatusResponse",
        "type": "object"
      },
      "JobSubmitRequest": {
        "description": "Request body for ''POST /api/v1/jobs''.\n\nAttributes\n----------\nscenario:\n    Raw scenario mapping with the same structure as a scenario YAML file\n    (''schema_version'', ''project'', ''load'', ''components'', etc.).\nrun_dir_name:\n    Optional custom stem for the run output directory.  When ''None'',\n    the service creates a subdirectory named by the job's ''run_id''.",
        "properties": {
          "run_dir_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Run Dir Name"
          },
          "scenario": {
            "additionalProperties": true,
            "description": "Scenario mapping with the same structure as a scenario YAML file (schema_version, project, location, load, components, tariff, ...). Validated against the SAMBA Scenario model; see scenario.schema.json for the full shape.",
            "title": "Scenario",
            "type": "object"
          }
        },
        "required": [
          "scenario"
        ],
        "title": "JobSubmitRequest",
        "type": "object"
      },
      "JobSubmitResponse": {
        "description": "Response body for ''POST /api/v1/jobs'' (HTTP 202 Accepted).\n\nAttributes\n----------\nrun_id:\n    UUID4 string identifying the submitted job.\nstatus:\n    Initial status -- always ''\"pending\"'' immediately after submission.\npoll_url:\n    Relative URL for polling job state:\n    ''/api/v1/jobs/{run_id}''.",
        "properties": {
          "poll_url": {
            "title": "Poll Url",
            "type": "string"
          },
          "run_id": {
            "title": "Run Id",
            "type": "string"
          },
          "status": {
            "const": "pending",
            "default": "pending",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "run_id",
          "poll_url"
        ],
        "title": "JobSubmitResponse",
        "type": "object"
      },
